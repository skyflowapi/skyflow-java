{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/checkstyle-on-edit.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mvn *)",
      "Bash(java *)",
      "Bash(python3 *)",
      "Bash(git *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(npx cspell *)"
    ],
    "deny": [
      "Edit(src/main/java/com/skyflow/generated/**)",
      "Write(src/main/java/com/skyflow/generated/**)"
    ]
  }
}
